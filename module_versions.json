      "runtimeSurface": "module version manifest"
    },
    {
      "id": "ingredients",
      "kind": "android-package",
      "path": "app/src/main/java/com/b2/ultraprocessed/ingredients",
      "version": "1.0.0",
      "runtimeSurface": "module version manifest"
