    },
    {
      "id": "camera",
      "kind": "android-package",
      "path": "app/src/main/java/com/b2/ultraprocessed/camera",
      "version": "1.0.0",
      "runtimeSurface": "module version manifest"
    },
    {
      "id": "classify",
      "kind": "android-package",
      "path": "app/src/main/java/com/b2/ultraprocessed/classify",
