    {
      "id": "network",
      "kind": "android-package",
      "path": "app/src/main/java/com/b2/ultraprocessed/network",
      "version": "1.0.0",
      "runtimeSurface": "module version manifest"
    },
    {
      "id": "ocr",
      "kind": "android-package",
      "path": "app/src/main/java/com/b2/ultraprocessed/ocr",
      "version": "1.0.0",
